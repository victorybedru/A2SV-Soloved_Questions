class Solution:
    def scoreOfParentheses(self, s: str) -> int:
        stack = []
        for char in s:
            if char == "(":
                stack.append("(")
            else: 
                inner_score = 0
                while stack and isinstance(stack[-1], int):
                    inner_score += stack.pop()
                stack.pop() 
                stack.append(max(1, 2*inner_score))
        return sum(stack)
