class Solution:
    def twoCitySchedCost(self, costs: List[List[int]]) -> int:
        costs.sort(key= lambda x: x[0]-x[1])
        n= len(costs)
        half= n//2
        total=0
        for i in range(half):
            total+= costs[i][0]
        for i in range(half, 2*half):
            total+= costs[i][1]
        return total
