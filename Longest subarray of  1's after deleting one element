class Solution:
    def longestSubarray(self, nums: List[int]) -> int:
        left=0
        count0=0
        longest=0
        for right in range(len(nums)):
            if nums[right]!=1:
                count0+=1
            while count0>1:
                if nums[left]==0:
                    count0-=1
                left+=1
            longest= max(right-left, longest)
        return longest
