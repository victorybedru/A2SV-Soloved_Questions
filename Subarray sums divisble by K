class Solution:
    def subarraysDivByK(self, nums: List[int], k: int) -> int:
        res=0
        summation= 0
        hashmap={0:1}
        for num in nums:
            summation+=num
            res+= hashmap.get(summation%k,0)
            hashmap[summation%k]= hashmap.get(summation%k, 0)+1
        return res
